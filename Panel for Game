   void Start()
   {
      Time.timeScale = 1f;
      _panel.SetActive(false);
   }
   private void Update()
   {
    
      if (Input.GetKeyDown(KeyCode.Escape))
      {
         if (Time.timeScale == 1f)
         {
            Time.timeScale = 0f;
            _panel.SetActive(true);
         }
         // Если игра уже на паузе (время = 0), значит нужно снять с паузы
         else
         {
            Time.timeScale = 1f;
            _panel.SetActive(false);
         }
